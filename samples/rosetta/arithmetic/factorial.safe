package Factorial is

   type Count is range 0 .. 7;
   type Value is range 1 .. 1_000_000;

   function Compute (N : Count) return Value is
      Product : Value = 1;
   begin
      if N == 0 then
         return 1;
      end if;

      for I in 1 .. N loop
         Product = Product * Value (I);
      end loop;

      return Product;
   end Compute;

end Factorial;
