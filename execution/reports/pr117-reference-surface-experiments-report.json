        "Next  : payload_ptr;",
        "Source : payload_ptr = new ((value = 42, Next = null) as payload);",
        "Target : payload_ptr = null;"
      ]
    },
    {
      "forbidden_fragments": [
        ".all"
      ],
      "mode": "combined",
      "name": "combined_reference_signal_and_implicit_deref",
      "required_fragments": [
