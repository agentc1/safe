-- Test: pr118b1_transitive_local_task_clause
-- Description: Task send contracts account for transitive local subprogram calls.
-- Expected: ACCEPT

package pr118b1_transitive_local_task_clause

   subtype message is integer (0 to 10);

   channel data_ch : message capacity 1;

   function push_data

      send data_ch, 1

   task producer with priority = 10, sends data_ch

      loop
         push_data
