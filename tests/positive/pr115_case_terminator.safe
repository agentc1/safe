package PR115_Case_Terminator is

   type Switch is range 0 to 1;

   function Normalize (Input : Switch) returns Boolean is
   begin
      var Result : Boolean = False
      case Input is
         when 0 then
            Result = False;
         end when;
         when others then
            Result = True;
         end when;
      end case
      return Result
   end Normalize;

end PR115_Case_Terminator;
