-- Test: pr113_tuple_channel
-- Description: Tuple-typed channel send/receive with copyable tuple elements.
-- Expected: ACCEPT

package PR113_Tuple_Channel is

   channel Pair_Ch : (Boolean, Integer) capacity 1;
   Result : Integer = 0;

   task Producer with Priority = 10 is
   begin
      loop
         send Pair_Ch, (True, 41);
         delay 0.05;
      end loop;
   end Producer;

   task Consumer with Priority = 10 is
      Payload : (Boolean, Integer);
   begin
      loop
         receive Pair_Ch, Payload;
         if Payload.1 then
            Result = Payload.2;
         end if;
      end loop;
   end Consumer;

end PR113_Tuple_Channel;
