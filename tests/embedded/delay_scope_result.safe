-- Test: delay_scope_result
-- Description: Delay-arm locals remain scoped correctly under embedded tasking.
-- Expected embedded result: 2

package delay_scope_result

   subtype message is integer (0 to 10);
   subtype total_count is integer (0 to 2);

   channel data_ch : message capacity 1;
   result : total_count = 0;

   task worker with priority = 10
      loop
         select
            when item : message from data_ch
               result = 0
         or
            delay 0.01
               temp : integer = 1;
               temp = temp + 1;
               result = total_count (temp)
